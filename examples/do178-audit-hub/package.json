{
  "name": "do178-audit-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DO-178C Audit Hub — reusable audit and evidence explorer for DO-178C / DO-331 programs (deterministic AeroNav sample, frontend only).",
