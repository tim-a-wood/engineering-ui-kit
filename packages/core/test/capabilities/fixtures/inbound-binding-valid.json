{
  "schemaVersion": "1.0",
  "bindingId": "binding.approve",
  "version": "1.0.0",
  "projectId": "proj-1",
  "deployableId": "web",
  "kind": "ui",
  "operationId": "op.orders.approve",
  "operationVersion": "1.0.0",
  "inputMappings": [{ "from": "form.orderId", "to": "input.orderId" }],
  "outputMappings": [{ "from": "output.approved", "to": "view.status" }],
  "validationBehavior": "inline field errors",
  "domainRejectionBehavior": "show rejection banner",
  "technicalFailureBehavior": "retry toast",
  "timeoutBehavior": "cancel after deadline",
  "cancellationBehavior": "abort on unmount",
  "retryBehavior": "manual",
  "duplicateSubmissionBehavior": "disable while pending",
  "exposure": "private",
  "generatedTargets": ["src/ui/ApproveButton.tsx", "src/ui/approveClient.ts"],
  "approvalState": "approved",
  "transport": "browser-local",
  "trigger": "activate"
}
