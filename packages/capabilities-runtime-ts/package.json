{
  "name": "@engineering-ui-kit/capabilities-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Framework-neutral runtime core for Engineering UI Kit Capabilities: operation/outcome model, dispatcher, validation, lifecycle container, cancellation/timeouts, configuration and secret-reference protocols, and an in-memory test harness. Host adapters (Node/browser/React/Electron) are delivered in a later package increment.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./electron/renderer": {
      "types": "./dist/electron/renderer.d.ts",
      "default": "./dist/electron/renderer.js"
    },
    "./electron/renderer-transport": {
      "types": "./dist/electron/renderer-transport.d.ts",
      "default": "./dist/electron/renderer-transport.js"
    },
    "./electron/preload": {
      "types": "./dist/electron/preload.d.ts",
      "default": "./dist/electron/preload.js"
    },
    "./electron/main": {
      "types": "./dist/electron/main.d.ts",
      "default": "./dist/electron/main.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "electron": ">=30.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "electron": "^43.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
