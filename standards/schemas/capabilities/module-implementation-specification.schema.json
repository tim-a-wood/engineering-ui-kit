{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engineering-ui-kit/standards/schemas/capabilities/module-implementation-specification.schema.json",
  "title": "ModuleImplementationSpecification",
  "description": "CAP-CONTRACT-031 — canonical, implementation-ready module specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "moduleId",
    "moduleVersion",
    "moduleType",
    "runtimeLanguage",
    "deployableId",
    "ownedPaths",
    "editablePaths",
    "responsibility",
    "nonResponsibilities",
    "providedOperations",
    "requiredOperations",
    "providedPorts",
    "requiredPorts",
    "canonicalSchemaRefs",
    "generatedTypeTargets",
    "rules",
    "invariants",
    "examples",
    "edgeCases",
    "failureSemantics",
    "performanceConstraints",
    "cancellationExpectations",
    "timeoutExpectations",
    "concurrencyExpectations",
    "lifecycleRegistration",
    "configurationRefs",
    "secretReferenceIds",
    "persistenceExpectations",
    "telemetryExpectations",
    "healthExpectations",
    "implementationSteps",
    "acceptanceCases",
    "acceptanceCommands",
    "unresolvedItems"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "projectId": { "type": "string" },
    "moduleId": { "type": "string" },
    "moduleVersion": { "type": "string" },
    "moduleType": { "type": "string", "enum": ["domain", "workflow", "experience", "connection", "platform"] },
    "runtimeLanguage": { "type": "string", "enum": ["typescript", "python"] },
    "deployableId": { "type": "string" },
    "ownedPaths": { "type": "array", "items": { "type": "string" } },
    "editablePaths": { "type": "array", "items": { "type": "string" } },
    "responsibility": { "type": "string" },
    "nonResponsibilities": { "type": "array", "items": { "type": "string" } },
    "providedOperations": {
      "type": "array",
      "items": { "type": "object", "required": ["operationId", "contractVersion"], "properties": { "operationId": { "type": "string" }, "contractVersion": { "type": "string" } } }
    },
    "requiredOperations": {
      "type": "array",
      "items": { "type": "object", "required": ["operationId", "acceptedContractRange", "reason"], "properties": { "operationId": { "type": "string" }, "acceptedContractRange": { "type": "string" }, "reason": { "type": "string" } } }
    },
    "providedPorts": { "type": "array", "items": { "type": "string" } },
    "requiredPorts": { "type": "array", "items": { "type": "string" } },
    "canonicalSchemaRefs": { "type": "array", "items": { "type": "string" } },
    "generatedTypeTargets": { "type": "array", "items": { "type": "string" } },
    "rules": {
      "type": "array",
      "items": { "type": "object", "required": ["id", "text"], "properties": { "id": { "type": "string" }, "text": { "type": "string" } } }
    },
    "invariants": { "type": "array", "items": { "type": "string" } },
    "examples": { "type": "array", "items": { "type": "string" } },
    "edgeCases": { "type": "array", "items": { "type": "string" } },
    "failureSemantics": { "type": "array", "items": { "type": "string" } },
    "performanceConstraints": { "type": "array", "items": { "type": "string" } },
    "cancellationExpectations": { "type": "string" },
    "timeoutExpectations": { "type": "string" },
    "concurrencyExpectations": { "type": "string" },
    "lifecycleRegistration": { "type": "string", "enum": ["singleton", "request-job", "transient"] },
    "configurationRefs": { "type": "array", "items": { "type": "string" } },
    "secretReferenceIds": { "type": "array", "items": { "type": "string" } },
    "persistenceExpectations": { "type": "string" },
    "telemetryExpectations": { "type": "string" },
    "healthExpectations": { "type": "string" },
    "implementationSteps": { "type": "array", "items": { "type": "string" } },
    "acceptanceCases": {
      "type": "array",
      "items": { "type": "object", "required": ["id", "description", "expectedOutcome"], "properties": { "id": { "type": "string" }, "description": { "type": "string" }, "expectedOutcome": { "type": "string" }, "kind": { "type": "string", "enum": ["example", "failure"] } } }
    },
    "acceptanceCommands": { "type": "array", "items": { "type": "string" } },
    "unresolvedItems": {
      "type": "array",
      "items": { "type": "object", "required": ["id", "description", "materiality"], "properties": { "id": { "type": "string" }, "description": { "type": "string" }, "materiality": { "type": "string", "enum": ["material", "non-material"] } } }
    }
  }
}
