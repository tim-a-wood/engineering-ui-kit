{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/engineering-ui-kit/capabilities/azure-devops-provenance.schema.json",
  "title": "CAP-CONTRACT-020",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "organization",
    "project",
    "externalType",
    "externalId",
    "revision",
    "retrievedAt",
    "contentHash",
    "sourceAdapterVersion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "organization": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "externalType": {
      "type": "string",
      "minLength": 1
    },
    "externalId": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string"
    },
    "retrievedAt": {
      "type": "string",
      "minLength": 1
    },
    "contentHash": {
      "type": "string",
      "minLength": 1
    },
    "fieldMapping": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "sourceAdapterVersion": {
      "type": "string",
      "minLength": 1
    },
    "pipelineRunId": {
      "type": "string"
    },
    "testRunId": {
      "type": "string"
    },
    "artifactId": {
      "type": "string"
    }
  }
}
