{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/engineering-ui-kit/capabilities/job-record.schema.json",
  "title": "CAP-CONTRACT-007",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "jobId",
    "projectId",
    "operationId",
    "operationVersion",
    "inputHash",
    "state",
    "createdAt",
    "updatedAt",
    "diagnostics",
    "artifactRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "operationId": {
      "type": "string",
      "minLength": 1
    },
    "operationVersion": {
      "type": "string",
      "minLength": 1
    },
    "inputHash": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "progress": {
      "type": "object",
      "properties": {
        "ratio": {
          "type": "number"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    },
    "startedAt": {
      "type": "string"
    },
    "completedAt": {
      "type": "string"
    },
    "cancellationRequested": {
      "type": "boolean"
    },
    "resultRef": {
      "type": "string"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "code",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "relatedIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
