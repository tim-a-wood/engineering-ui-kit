{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engineering-ui-kit/standards/schemas/capabilities/generated-ownership-manifest.schema.json",
  "title": "GeneratedOwnershipManifest",
  "description": "CAP-CONTRACT-026 — generated file ownership record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "filePath",
    "contentHash",
    "generatorVersion",
    "referenceProfileVersion",
    "sourceContractHashes",
    "deployableId",
    "moduleIds",
    "lastAppliedPlanId",
    "safeToDelete"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "projectId": { "type": "string" },
    "filePath": { "type": "string" },
    "contentHash": { "type": "string" },
    "generatorVersion": { "type": "string" },
    "referenceProfileVersion": { "type": "string" },
    "sourceContractHashes": { "type": "array", "items": { "type": "string" } },
    "deployableId": { "type": "string" },
    "moduleIds": { "type": "array", "items": { "type": "string" } },
    "lastAppliedPlanId": { "type": "string" },
    "safeToDelete": { "type": "boolean" }
  }
}
