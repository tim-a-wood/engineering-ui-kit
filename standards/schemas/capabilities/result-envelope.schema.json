{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/engineering-ui-kit/capabilities/result-envelope.schema.json",
  "title": "CAP-CONTRACT-005",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "outcome",
    "diagnostics",
    "artifacts",
    "provenance"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "outcome": {
      "enum": [
        "success",
        "domain-rejection",
        "technical-failure",
        "cancelled"
      ]
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "code",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "relatedIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "source",
        "recordedAt"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "recordedAt": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string"
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "value": true,
    "rejection": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object"
    }
  }
}
