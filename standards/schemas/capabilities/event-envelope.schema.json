{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/engineering-ui-kit/capabilities/event-envelope.schema.json",
  "title": "CAP-CONTRACT-010",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "eventType",
    "eventVersion",
    "moduleId",
    "projectId",
    "occurredAt",
    "payloadSchemaRef",
    "payload",
    "provenance"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "eventVersion": {
      "type": "string",
      "minLength": 1
    },
    "moduleId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "occurredAt": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string"
    },
    "causationId": {
      "type": "string"
    },
    "payloadSchemaRef": {
      "type": "string",
      "minLength": 1
    },
    "payload": true,
    "provenance": {
      "type": "object",
      "required": [
        "source",
        "recordedAt"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "recordedAt": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string"
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
